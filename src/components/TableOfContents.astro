---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
---

{
	toc.length > 0 && (
		<aside class="toc">
			<h2>On this page</h2>
			<ul>
				{toc.map((heading) => (
					<li class={`toc__item toc__item--depth-${heading.depth}`}>
						<a href={`#${heading.slug}`}>{heading.text}</a>
					</li>
				))}
			</ul>
		</aside>
	)
}

<style>
	.toc {
		position: sticky;
		top: 5rem;
		align-self: start;
		padding-left: 1.5rem;
		border-left: 1px solid var(--color-border);
	}

	.toc h2 {
		font-size: 0.9rem;
		margin-bottom: 1rem;
	}

	.toc ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.75rem;
	}

	.toc__item a {
		color: var(--color-muted);
		text-decoration: none;
		font-size: 0.94rem;
	}

	.toc__item--depth-3 {
		padding-left: 0.8rem;
	}

	@media (max-width: 960px) {
		.toc {
			position: static;
			padding-left: 0;
			padding-top: 1rem;
			border-left: 0;
			border-top: 1px solid var(--color-border);
		}
	}
</style>
