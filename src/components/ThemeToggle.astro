<button
	class="theme-toggle"
	type="button"
	aria-label="Toggle dark mode"
	data-theme-toggle
>
	<span aria-hidden="true" class="theme-toggle__icon theme-toggle__icon--sun">Light</span>
	<span aria-hidden="true" class="theme-toggle__icon theme-toggle__icon--moon">Dark</span>
</button>

<script is:inline>
	const root = document.documentElement;
	const key = 'theme-preference';
	const saved = localStorage.getItem(key);
	const preferredDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
	const theme = saved ?? (preferredDark ? 'dark' : 'light');

	root.dataset.theme = theme;

	const button = document.querySelector('[data-theme-toggle]');
	button?.addEventListener('click', () => {
		const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
		root.dataset.theme = next;
		localStorage.setItem(key, next);
	});
</script>

<style>
	.theme-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		background: transparent;
		color: var(--color-text);
		padding: 0.45rem 0.8rem;
		font: inherit;
		cursor: pointer;
	}

	.theme-toggle__icon {
		font-size: 0.78rem;
		letter-spacing: 0.04em;
		text-transform: uppercase;
	}

	.theme-toggle__icon--moon {
		opacity: 0.55;
	}

	:global(:root[data-theme='dark']) .theme-toggle__icon--sun {
		opacity: 0.55;
	}

	:global(:root[data-theme='dark']) .theme-toggle__icon--moon {
		opacity: 1;
	}
</style>
