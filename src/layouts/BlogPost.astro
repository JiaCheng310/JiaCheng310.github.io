---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import { slugifyTag } from '../utils/blog';

type Heading = {
	depth: number;
	slug: string;
	text: string;
};

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: Heading[];
};

const { title, description, pubDate, updatedDate, heroImage, tags = [], headings = [] } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main class="post-shell">
			<article class="post">
				<header class="post__header">
					<p class="post__eyebrow">Essay</p>
					<h1>{title}</h1>
					<p class="post__description">{description}</p>
					<div class="post__meta">
						<span><FormattedDate date={pubDate} /></span>
						{updatedDate && <span>Updated <FormattedDate date={updatedDate} /></span>}
					</div>
					{
						tags.length > 0 && (
							<ul class="post__tags" aria-label="Post tags">
								{tags.map((tag) => (
									<li>
										<a href={`/tags/${slugifyTag(tag)}/`}>{tag}</a>
									</li>
								))}
							</ul>
						)
					}
				</header>

				{heroImage && (
					<div class="post__hero">
						<Image width={1280} height={720} src={heroImage} alt="" />
					</div>
				)}

				<div class="post__body">
					<div class="prose">
						<slot />
					</div>
					<TableOfContents headings={headings} />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-shell {
		padding-top: 1rem;
	}

	.post {
		display: grid;
		gap: 2rem;
	}

	.post__header {
		max-width: 46rem;
	}

	.post__eyebrow {
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-muted);
		margin-bottom: 0.6rem;
	}

	.post__description {
		font-size: 1.05rem;
		color: var(--color-muted);
		max-width: 40rem;
	}

	.post__meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
		font-size: 0.95rem;
		color: var(--color-muted);
	}

	.post__tags {
		list-style: none;
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding: 0;
		margin: 1.25rem 0 0;
	}

	.post__tags a {
		display: inline-flex;
		padding: 0.32rem 0.65rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		text-decoration: none;
		font-size: 0.88rem;
	}

	.post__hero img {
		width: 100%;
	}

	.post__body {
		display: grid;
		grid-template-columns: minmax(0, 46rem) minmax(0, 14rem);
		gap: 3rem;
		align-items: start;
	}

	.prose {
		min-width: 0;
	}

	.prose :global(h2),
	.prose :global(h3) {
		scroll-margin-top: 5rem;
	}

	.prose :global(p + h2),
	.prose :global(ul + h2),
	.prose :global(pre + h2) {
		margin-top: 2.5rem;
	}

	@media (max-width: 960px) {
		.post__body {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}
</style>
