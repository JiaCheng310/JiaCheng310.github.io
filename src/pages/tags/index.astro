---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';
import { getUniqueTags, slugifyTag } from '../../utils/blog';

const posts = (await getCollection('blog')).filter((post) => !post.data.draft);
const tags = getUniqueTags(posts);
---

<BaseLayout title={`Tags | ${SITE_TITLE}`} description="Browse posts by topic">
	<section class="tags">
		<p class="tags__eyebrow">Tags</p>
		<h1>Topics</h1>
		<ul class="tags__list">
			{tags.map((tag) => (
				<li>
					<a href={`/tags/${slugifyTag(tag)}/`}>{tag}</a>
				</li>
			))}
		</ul>
	</section>
</BaseLayout>

<style>
	.tags {
		max-width: 42rem;
	}

	.tags__eyebrow {
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.tags__list {
		list-style: none;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.9rem;
	}

	.tags__list a {
		display: inline-flex;
		padding: 0.45rem 0.8rem;
		border: 1px solid var(--color-border);
		border-radius: 999px;
		text-decoration: none;
	}
</style>
