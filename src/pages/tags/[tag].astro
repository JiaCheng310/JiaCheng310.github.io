---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_TITLE } from '../../consts';
import { slugifyTag, sortPosts } from '../../utils/blog';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).filter((post) => !post.data.draft);
	const tags = [...new Set(posts.flatMap((post) => post.data.tags ?? []))];

	return tags.map((tag) => ({
		params: { tag: slugifyTag(tag) },
		props: {
			tag,
			posts: sortPosts(posts.filter((post) => post.data.tags.includes(tag))),
		},
	}));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`${tag} | ${SITE_TITLE}`} description={`Posts tagged ${tag}`}>
	<section class="tag-page">
		<p class="tag-page__eyebrow">Tag</p>
		<h1>{tag}</h1>
		<ul class="tag-page__list">
			{
				posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`} class="tag-page__item">
							<div>
								<h2>{post.data.title}</h2>
								<p>{post.data.description}</p>
							</div>
							<span><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</BaseLayout>

<style>
	.tag-page {
		max-width: 52rem;
	}

	.tag-page__eyebrow {
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-muted);
	}

	.tag-page__list {
		list-style: none;
		padding: 0;
		margin: 1.5rem 0 0;
		border-top: 1px solid var(--color-border);
	}

	.tag-page__item {
		display: flex;
		justify-content: space-between;
		gap: 1.5rem;
		padding: 1.1rem 0;
		border-bottom: 1px solid var(--color-border);
		text-decoration: none;
	}

	.tag-page__item h2 {
		font-size: 1.08rem;
		margin-bottom: 0.35rem;
	}

	.tag-page__item p,
	.tag-page__item span {
		color: var(--color-muted);
	}

	.tag-page__item span {
		white-space: nowrap;
		font-size: 0.92rem;
	}

	@media (max-width: 640px) {
		.tag-page__item {
			flex-direction: column;
			gap: 0.65rem;
		}
	}
</style>
