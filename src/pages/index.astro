---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import SearchBox from '../components/SearchBox.astro';
import {
	AUTHOR_BIO,
	AUTHOR_HANDLE,
	HOME_INTRO,
	SITE_DESCRIPTION,
	SITE_TITLE,
} from '../consts';
import { sortPosts } from '../utils/blog';

const posts = sortPosts((await getCollection('blog')).filter((post) => !post.data.draft)).slice(0, 5);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<section class="hero">
		<p class="hero__kicker">{AUTHOR_HANDLE}</p>
		<h1>{SITE_TITLE}</h1>
		<p class="hero__bio">{AUTHOR_BIO}</p>
		<div class="hero__body">
			{HOME_INTRO.map((paragraph) => <p>{paragraph}</p>)}
		</div>
	</section>

	<section class="home-grid">
		<div class="home-grid__main">
			<div class="section-heading">
				<h2>Recent writing</h2>
				<a href="/blog">View archive</a>
			</div>
			<ul class="post-list">
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`} class="post-list__item">
								<div>
									<h3>{post.data.title}</h3>
									<p>{post.data.description}</p>
								</div>
								<span><FormattedDate date={post.data.pubDate} /></span>
							</a>
						</li>
					))
				}
			</ul>
		</div>

		<div class="home-grid__side">
			<SearchBox />
		</div>
	</section>
</BaseLayout>

<style>
	.hero {
		max-width: 46rem;
		display: grid;
		gap: 1rem;
		margin-bottom: 3rem;
	}

	.hero__kicker {
		margin: 0;
		color: var(--color-muted);
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.hero__bio {
		font-size: 1.1rem;
		color: var(--color-muted);
		max-width: 40rem;
	}

	.hero__body {
		display: grid;
		gap: 1rem;
		max-width: 42rem;
	}

	.home-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.5fr) minmax(18rem, 1fr);
		gap: 3rem;
		align-items: start;
	}

	.section-heading {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.section-heading h2 {
		font-size: 1rem;
	}

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 1px solid var(--color-border);
	}

	.post-list__item {
		display: flex;
		justify-content: space-between;
		gap: 1.5rem;
		padding: 1rem 0;
		border-bottom: 1px solid var(--color-border);
		text-decoration: none;
	}

	.post-list__item h3 {
		font-size: 1.05rem;
		margin-bottom: 0.35rem;
	}

	.post-list__item p,
	.post-list__item span {
		color: var(--color-muted);
	}

	.post-list__item span {
		white-space: nowrap;
		font-size: 0.92rem;
	}

	@media (max-width: 960px) {
		.home-grid {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
	}

	@media (max-width: 640px) {
		.post-list__item {
			flex-direction: column;
			gap: 0.65rem;
		}
	}
</style>
